# Camera Monitor 环境变量配置
# 复制此文件为 .env 并修改

# ── 端口 ──
BACKEND_PORT=8088
FRONTEND_PORT=8080

# ── 安全 ──
JWT_SECRET=change-this-to-a-random-string
ADMIN_PASSWORD=admin123

# ── 飞书机器人（可选）─→
FEISHU_APP_ID=
FEISHU_APP_SECRET=

# ── 检测参数 ──
DETECT_TIMEOUT=5

# ── 构建加速（国内用户取消注释）──
# PIP_INDEX_URL=https://mirrors.tuna.tsinghua.edu.cn/pypi/web/simple
# NPM_REGISTRY=https://registry.npmmirror.com
